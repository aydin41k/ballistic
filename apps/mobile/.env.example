# The base URL of the Ballistic backend API.
# For local development this is usually http://localhost:8000 (iOS simulator)
# or http://10.0.2.2:8000 (Android emulator).
# For a real device on the same LAN use your machine's LAN IP, e.g. http://192.168.1.x:8000
# For production set this to your deployed backend URL (must be https://).
EXPO_PUBLIC_API_BASE_URL=
