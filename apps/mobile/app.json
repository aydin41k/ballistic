{
  "expo": {
    "name": "Ballistic",
    "slug": "ballistic-mobile",
    "version": "0.2.7",
    "orientation": "portrait",
    "icon": "./assets/images/ballistic-icon.png",
    "scheme": "ballistic",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F7F8FA",
    "ios": {
      "icon": "./assets/images/ballistic-icon.png",
      "bundleIdentifier": "com.psycode.ballistic",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "icon": "./assets/images/ballistic-icon.png",
      "package": "com.psycode.ballistic",
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": true,
      "permissions": ["POST_NOTIFICATIONS"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/ballistic-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A2540",
          "image": "./assets/images/ballistic-logo.png",
          "imageWidth": 180,
          "resizeMode": "contain"
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "color": "#1E40AF",
          "defaultChannel": "ballistic"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Ballistic to choose a profile photo.",
          "cameraPermission": "Allow Ballistic to take a profile photo.",
          "microphonePermission": false
        }
      ],
      "./plugins/with-image-picker-crop-theme"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2f0e4af2-5da0-4024-93bb-a64c6176d9d8"
      }
    },
    "owner": "aydin4ik"
  }
}
